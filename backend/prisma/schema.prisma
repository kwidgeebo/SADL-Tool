generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(DESIGNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  projects  Project[]
  approvals Approval[]
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  phases      Phase[]
}

model Phase {
  id        String    @id @default(cuid())
  type      PhaseType
  status    PhaseStatus @default(DRAFT)
  data      Json?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  projectId String
  project   Project   @relation(fields: [projectId], references: [id])
  documents Document[]
  approvals Approval[]
}

model Document {
  id        String   @id @default(cuid())
  title     String
  type      String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  phaseId   String
  phase     Phase    @relation(fields: [phaseId], references: [id])
}

model Approval {
  id        String         @id @default(cuid())
  status    ApprovalStatus @default(PENDING)
  comments  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  phaseId   String
  phase     Phase          @relation(fields: [phaseId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
}

enum Role {
  DESIGNER
  MANAGER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum PhaseType {
  ANALYSE
  DESIGN
  DEVELOP
  IMPLEMENT
  EVALUATE
}

enum PhaseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}