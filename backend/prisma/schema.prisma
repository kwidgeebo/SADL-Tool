generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===========================
// ENUMS FIRST
// ===========================

enum Role {
  DESIGNER
  MANAGER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum PhaseType {
  ANALYSE
  DESIGN
  DEVELOP
  IMPLEMENT
  EVALUATE
}

enum PhaseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum RiskRating {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum Difficulty {
  EASY
  STRAIGHTFORWARD
  DIFFICULT
  VERY_DIFFICULT
}

enum Frequency {
  RARELY
  BIANNUALLY
  QUARTERLY
  MONTHLY
  WEEKLY
  DAILY
}

enum Importance {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum GapType {
  NO_GAP
  SIMPLE
  COMPLEX
}

enum OptionType {
  NO_ACTION
  NON_LD
  LD_NON_TRAINING
  LD_TRAINING
}

enum OutputType {
  TRS
  LDS
}

// ===========================
// CORE MODELS
// ===========================

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String
  name      String
  role      Role       @default(DESIGNER)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  projects  Project[]
  approvals Approval[]
}

model Project {
  id           String        @id @default(cuid())
  title        String
  description  String?
  status       ProjectStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  phases       Phase[]
  analysePhase AnalysePhase?
  designPhase  DesignPhase? 
  developPhase DevelopPhase?
}

model Phase {
  id        String      @id @default(cuid())
  type      PhaseType
  status    PhaseStatus @default(DRAFT)
  data      Json?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  projectId String
  project   Project     @relation(fields: [projectId], references: [id])
  approvals Approval[]
}

model Approval {
  id        String         @id @default(cuid())
  status    ApprovalStatus @default(PENDING)
  comments  String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  phaseId   String
  phase     Phase          @relation(fields: [phaseId], references: [id])
  userId    String
  user      User           @relation(fields: [userId], references: [id])
}

// ===========================
// ANALYSE PHASE MODELS
// ===========================

model AnalysePhase {
  id                String                   @id @default(cuid())
  status            PhaseStatus              @default(DRAFT)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt
  projectId         String                   @unique
  project           Project                  @relation(fields: [projectId], references: [id])
  inputAnalysis     InputAnalysis?
  jobTaskProfile    JobTaskProfile?
  jobSpecification  JobSpecification?
  targetPopulation  TargetPopulationProfile?
  gapAnalysis       GapAnalysisStatement?
  feasibilityReport FeasibilityReport?
  analyseOutput     AnalyseOutput?
  riskAssessment    RiskAssessment?
}

model InputAnalysis {
  id                    String       @id @default(cuid())
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  analysePhaseId        String       @unique
  analysePhase          AnalysePhase @relation(fields: [analysePhaseId], references: [id])
  triggerLegislative    Boolean      @default(false)
  triggerPolicy         Boolean      @default(false)
  triggerNewCapability  Boolean      @default(false)
  triggerLessonsLearnt  Boolean      @default(false)
  triggerLearningReview Boolean      @default(false)
  triggerWorkplaceEval  Boolean      @default(false)
  triggerBusinessSkill  Boolean      @default(false)
  triggerCultural       Boolean      @default(false)
  triggerOther          Boolean      @default(false)
  triggerOtherDetails   String?
  projectBackground     String?
  currentStatus         String?
  linkedActivities      String?
  sadlAppropriate       Boolean?
  analyseRequired       Boolean?
  scopeNotes            String?
  requiredDeliverables  String?
  stakeholderNeeds      String?
  timeFactors           String?
  resourcesRequired     String?
  rolesResponsibilities String?
  communicationProcess  String?
  oqeProvided           Boolean?
  oqeNotes              String?
}

model RiskAssessment {
  id                 String       @id @default(cuid())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  analysePhaseId     String       @unique
  analysePhase       AnalysePhase @relation(fields: [analysePhaseId], references: [id])
  projectBackground  String?
  sadlProcessUsed    String?
  sadlProcessOmitted String?
  rationaleOmissions String?
  risksOmissions     String?
  mitigationActions  String?
  residualRisk       String?
  overallRiskRating  RiskRating   @default(LOW)
}

model JobTaskProfile {
  id                    String       @id @default(cuid())
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  analysePhaseId        String       @unique
  analysePhase          AnalysePhase @relation(fields: [analysePhaseId], references: [id])
  jobTitle              String?
  jobDescription        String?
  organisationalContext String?
  licenceRequired       Boolean      @default(false)
  licenceDetails        String?
  tasks                 JobTask[]
}

model JobTask {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  jobTaskProfileId String
  jobTaskProfile   JobTaskProfile @relation(fields: [jobTaskProfileId], references: [id])
  taskNumber       Int
  taskDescription  String
  conditions       String?
  standards        String?
  difficulty       Difficulty     @default(STRAIGHTFORWARD)
  frequency        Frequency      @default(MONTHLY)
  importance       Importance     @default(MEDIUM)
  subTasks         SubTask[]
}

model SubTask {
  id          String  @id @default(cuid())
  jobTaskId   String
  jobTask     JobTask @relation(fields: [jobTaskId], references: [id])
  description String
  taskNumber  Int
}

model JobSpecification {
  id                  String       @id @default(cuid())
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt
  analysePhaseId      String       @unique
  analysePhase        AnalysePhase @relation(fields: [analysePhaseId], references: [id])
  jobTitle            String?
  numberOfPositions   Int?
  locationOfPositions String?
  anticipatedTurnover String?
  importanceLevel     String?
  classification      String?
  interRelationships  String?
  requiredMateriel    String?
  physicalConditions  String?
  physicalDemands     String?
  attributesRequired  String?
  careerFactors       String?
}

model TargetPopulationProfile {
  id                       String       @id @default(cuid())
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt
  analysePhaseId           String       @unique
  analysePhase             AnalysePhase @relation(fields: [analysePhaseId], references: [id])
  jobDesignation           String?
  jobSituation             String?
  jobDescription           String?
  jobFunction              String?
  jobOwner                 String?
  workEnvironment          String?
  employmentClassification String?
  geographicDistribution   String?
  qualifications           String?
  aptitudes                String?
  competencies             String?
  academicAbility          String?
  physicalCharacteristics  String?
  learningMethods          String?
  motivation               String?
  otherCharacteristics     String?
}

model GapAnalysisStatement {
  id             String             @id @default(cuid())
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  analysePhaseId String             @unique
  analysePhase   AnalysePhase       @relation(fields: [analysePhaseId], references: [id])
  gapExists      Boolean            @default(false)
  gapType        GapType            @default(SIMPLE)
  gapSummary     String?
  recommendation String?
  gapItems       GapItem[]
  overTraining   OverTrainingItem[]
}

model GapItem {
  id                       String               @id @default(cuid())
  gapAnalysisId            String
  gapAnalysis              GapAnalysisStatement @relation(fields: [gapAnalysisId], references: [id])
  taskReference            String?
  taskDescription          String?
  targetPopulationCapacity String?
  identifiedGap            String?
  currentLearningOutcome   String?
  difRating                String?
}

model OverTrainingItem {
  id              String               @id @default(cuid())
  gapAnalysisId   String
  gapAnalysis     GapAnalysisStatement @relation(fields: [gapAnalysisId], references: [id])
  learningOutcome String?
  assessment      String?
}

model FeasibilityReport {
  id             String              @id @default(cuid())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  analysePhaseId String              @unique
  analysePhase   AnalysePhase        @relation(fields: [analysePhaseId], references: [id])
  analysisProcess String?
  unitsConsulted String?
  recommendation String?
  options        FeasibilityOption[]
}

model FeasibilityOption {
  id                  String            @id @default(cuid())
  feasibilityReportId String
  feasibilityReport   FeasibilityReport @relation(fields: [feasibilityReportId], references: [id])
  optionType          OptionType        @default(NO_ACTION)
  optionDescription   String?
  advantages          String?
  disadvantages       String?
  risks               String?
  mitigationActions   String?
  recommended         Boolean           @default(false)
}

model AnalyseOutput {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  analysePhaseId   String         @unique
  analysePhase     AnalysePhase   @relation(fields: [analysePhaseId], references: [id])
  outputType       OutputType     @default(TRS)
  generatedContent Json?
  approvalStatus   ApprovalStatus @default(PENDING)
  approvalComments String?
}

// ===========================
// DESIGN PHASE ENUMS
// ===========================

enum TrainingLevel {
  LEVEL_1
  LEVEL_2
  LEVEL_3
  LEVEL_4
}

enum DeliveryMethod {
  INSTRUCTOR_LED
  SELF_PACED
  BLENDED
  ON_JOB
  SIMULATION
  E_LEARNING
  OTHER
}

enum AssessmentMethod {
  OBSERVATION
  WRITTEN_TEST
  PRACTICAL_EXERCISE
  PORTFOLIO
  ORAL_QUESTIONING
  SIMULATION_EXERCISE
  OTHER
}

enum KirkpatrickLevel {
  LEVEL_1_REACTION
  LEVEL_2_LEARNING
  LEVEL_3_BEHAVIOUR
  LEVEL_4_RESULTS
}


// ===========================
// DESIGN PHASE MODELS
// ===========================

model DesignPhase {
  id                   String                @id @default(cuid())
  status               PhaseStatus           @default(DRAFT)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  projectId            String                @unique
  project              Project               @relation(fields: [projectId], references: [id])
  des1InputAnalysis    Des1InputAnalysis?
  des2Environments     Des2Environments?
  des3LearningOutcomes Des3LearningOutcomes?
  des4CourseStructure  Des4CourseStructure?
  designOutput         DesignOutput?
}

// ---
// Des1 — Input Analysis
// Confirms documents reviewed, stakeholders, scope, updated risk for Design Phase
// ---
model Des1InputAnalysis {
  id                    String      @id @default(cuid())
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  designPhaseId         String      @unique
  designPhase           DesignPhase @relation(fields: [designPhaseId], references: [id])

  // Documents Reviewed
  trsReviewed           Boolean     @default(false)
  trsReference          String?
  jobTaskProfileReviewed Boolean    @default(false)
  targetPopulationReviewed Boolean  @default(false)
  gapAnalysisReviewed   Boolean     @default(false)
  feasibilityReviewed   Boolean     @default(false)
  otherDocsReviewed     Boolean     @default(false)
  otherDocsDetails      String?

  // Stakeholders
  stakeholders          String?
  smePanel              String?
  trainingAuthority     String?
  projectSponsor        String?

  // Scope Confirmation
  designRequired        Boolean?
  scopeNotes            String?
  designDeliverables    String?
  phasesOmitted         String?
  rationaleOmissions    String?

  // Updated Risk Assessment
  riskNotes             String?
  residualRisk          String?
  overallRiskRating     RiskRating  @default(LOW)
  mitigationActions     String?

  // Resources and Timeline
  timeFactors           String?
  resourcesRequired     String?
  rolesResponsibilities String?
  communicationProcess  String?
}

// ---
// Des2 — Environments Analysis
// Produces the Environments Profile (DesP2)
// ---
model Des2Environments {
  id                    String      @id @default(cuid())
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  designPhaseId         String      @unique
  designPhase           DesignPhase @relation(fields: [designPhaseId], references: [id])

  // Facility
  facilityDescription   String?
  facilityAccess        String?
  facilityLocation      String?

  // Activity Spaces
  activitySpaces        String?
  classroomCapacity     String?
  simulatorAccess       String?
  outdoorSpaces         String?

  // Resources
  equipmentAvailable    String?
  technologyInfrastructure String?
  learningMaterials     String?

  // Staff
  instructorAvailability String?
  instructorQualifications String?
  supportStaff          String?

  // Finances
  budgetAvailable       String?
  costConstraints       String?
  fundingSource         String?

  // Legislation and Policy
  relevantLegislation   String?
  whsRequirements       String?
  accessibilityRequirements String?
  securityRequirements  String?
}

// ---
// Des3 — Learning Outcomes
// The heart of the Design Phase — produces the full LO set
// ---
model Des3LearningOutcomes {
  id                    String            @id @default(cuid())
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  designPhaseId         String            @unique
  designPhase           DesignPhase       @relation(fields: [designPhaseId], references: [id])
  mappingMatrixApplies  Boolean           @default(false)
  mappingMatrixNotes    String?
  learningOutcomes      LearningOutcome[]
}

model LearningOutcome {
  id                    String              @id @default(cuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  des3Id                String
  des3                  Des3LearningOutcomes @relation(fields: [des3Id], references: [id])
  sequence              Int
  loName                String?

  // Five components
  performanceStatement  String?
  performanceConditions String?
  performanceStandard   String?
  assessmentCriteria    String?
  contentSummary        String?

  // Additional LMP fields
  trainingLevel         TrainingLevel       @default(LEVEL_1)
  deliveryMethod        DeliveryMethod      @default(INSTRUCTOR_LED)
  prerequisiteLOs       String?
  relatedAssessments    String?
  uocReference          String?             // VET Competency Unit — N/A if no formal qualification
  resources             String?
  references            String?

  // Duration (manually entered by designer)
  durationOnJobHours    Float?
  durationOnJobDays     Float?
  durationOffJobHours   Float?
  durationOffJobDays    Float?
  durationSummativeOnJobHours Float?
  durationSummativeOnJobDays  Float?
  durationSummativeOffJobHours Float?
  durationSummativeOffJobDays  Float?
  durationFormativeOffJobHours Float?
  durationFormativeOffJobDays  Float?
  durationOtherHours    Float?
  durationOtherDays     Float?
  durationOtherType     String?
}

// ---
// Des4 — Course Structure
// Assessment strategy, programme structure, evaluation plan, resources
// ---
model Des4CourseStructure {
  id                    String      @id @default(cuid())
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  designPhaseId         String      @unique
  designPhase           DesignPhase @relation(fields: [designPhaseId], references: [id])

  // Assessment Strategy
  formativeStrategy     String?
  summativeStrategy     String?
  assessorQualifications String?
  assessmentNotes       String?

  // Programme Structure
  courseAim             String?
  courseDescription     String?
  courseOverview        String?
  modules               Module[]

  // Learning Methods and Media
  primaryDeliveryMethod DeliveryMethod @default(INSTRUCTOR_LED)
  deliveryNotes         String?
  learningMethods       String?
  mediaRequirements     String?

  // Evaluation Plan
  evaluationPlan        EvaluationPlan[]

  // Course-level duration (rolled up, manually entered)
  totalOnJobHours       Float?
  totalOffJobHours      Float?
  totalDays             Float?

  // Resource Requirements (feeds Section 3 of LMP)
  humanResources        String?
  physicalResources     String?
  defenceSupportRequirements String?
  financialRequirements String?
  otherRequirements     String?

  // Section 1 LMP fields
  minStudents           Int?
  maxStudents           Int?
  courseLevel           String?
  courseType            String?
  servicePrerequisites  String?
  qualificationPrerequisites String?
  securityClearance     String?
  courseTargets         String?
  eligibilityDetails    String?
  additionalInformation String?
  trainingAuthorityDetails String?
  accreditationBody     String?
  avetmissInfo          String?
  authorityToUse        String?
  ipHolders             String?
  specialInstructions   String?
}

model Module {
  id                    String              @id @default(cuid())
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  des4Id                String
  des4                  Des4CourseStructure @relation(fields: [des4Id], references: [id])
  sequence              Int
  moduleId              String?             // e.g. "1", "1.1"
  moduleName            String?
  moduleContent         String?
  prerequisiteModules   String?
  deliveryMethod        DeliveryMethod      @default(INSTRUCTOR_LED)
  keyResources          String?
  whsRequirements       String?
  additionalComments    String?
  loAssignments         String?             // JSON array of LO ids assigned to this module

  // Duration (manually entered)
  durationOnJobHours    Float?
  durationOnJobDays     Float?
  durationOffJobHours   Float?
  durationOffJobDays    Float?
  durationSummativeOnJobHours  Float?
  durationSummativeOnJobDays   Float?
  durationSummativeOffJobHours Float?
  durationSummativeOffJobDays  Float?
  durationFormativeOffJobHours Float?
  durationFormativeOffJobDays  Float?
  durationOtherHours    Float?
  durationOtherDays     Float?
  durationOtherType     String?

  // Formative and summative assessments for this module
  formativeAssessments  FormativeAssessment[]
  summativeAssessments  SummativeAssessment[]
}

model FormativeAssessment {
  id              String  @id @default(cuid())
  moduleId        String
  module          Module  @relation(fields: [moduleId], references: [id])
  faId            String?
  faName          String?
  loAssessed      String?
  method          AssessmentMethod @default(OBSERVATION)
  description     String?
  assessmentCriteria String?
  additionalComments String?
  durationHours   Float?
  durationDays    Float?
}

model SummativeAssessment {
  id              String  @id @default(cuid())
  moduleId        String
  module          Module  @relation(fields: [moduleId], references: [id])
  saId            String?
  saName          String?
  loAssessed      String?
  method          AssessmentMethod @default(WRITTEN_TEST)
  description     String?
  assessmentCriteria String?
  uocReference    String?
  additionalComments String?
  durationHours   Float?
  durationDays    Float?
}

model EvaluationPlan {
  id                String              @id @default(cuid())
  des4Id            String
  des4              Des4CourseStructure @relation(fields: [des4Id], references: [id])
  kirkpatrickLevel  KirkpatrickLevel
  planDescription   String?
  timing            String?
  responsibility    String?
}

// ---
// Des5 — Design Output
// Compiled Draft LMP — progressive assembly, Des5 is review/finalise only
// ---
model DesignOutput {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  designPhaseId    String         @unique
  designPhase      DesignPhase    @relation(fields: [designPhaseId], references: [id])
  generatedContent Json?
  approvalStatus   ApprovalStatus @default(PENDING)
  approvalComments String?
}


// ===========================
// DEVELOP PHASE ENUM
// ===========================

enum PromptType {
  LESSON_PLAN
  INSTRUCTOR_GUIDE
  LEARNER_WORKBOOK
  PRACTICAL_ACTIVITY
  STORYBOARD
  ASSESSMENT_TOOL
  PRESENTATION_SLIDES
  COURSE_ADMIN
}


// ===========================
// DEVELOP PHASE MODELS
// ===========================

model DevelopPhase {
  id             String         @id @default(cuid())
  status         PhaseStatus    @default(DRAFT)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  projectId      String         @unique
  project        Project        @relation(fields: [projectId], references: [id])
  promptSets     PromptSet[]
  developOutput  DevelopOutput?
}

model PromptSet {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  developPhaseId String
  developPhase   DevelopPhase @relation(fields: [developPhaseId], references: [id])
  promptType     PromptType
  referenceId    String       // LO id, module id, assessment id, or "course"
  referenceName  String       // Display name — LO name, module name etc
  notes          String?      // Designer notes on this prompt/output
  copied         Boolean      @default(false)
  copiedAt       DateTime?
}

model DevelopOutput {
  id               String         @id @default(cuid())
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  developPhaseId   String         @unique
  developPhase     DevelopPhase   @relation(fields: [developPhaseId], references: [id])
  approvalStatus   ApprovalStatus @default(PENDING)
  approvalComments String?
}